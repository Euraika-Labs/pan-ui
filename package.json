{
  "name": "@euraika-labs/pan-ui",
  "version": "0.5.2",
  "description": "Beautiful WebUI for Hermes Agent — chat, skills, plugins, memory, profiles, and runtime diagnostics in one workspace.",
  "keywords": [
    "hermes",
    "agent",
    "webui",
    "workspace",
    "chat",
    "skills",
    "plugins",
    "mcp",
    "nous-research"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Euraika-Labs/pan-ui.git"
  },
  "homepage": "https://github.com/Euraika-Labs/pan-ui",
  "bin": {
    "pan-ui": "bin/pan-ui.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "hermes.version.json",
    ".env.example",
    "README.md"
  ],
  "scripts": {
